# 服务配置
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# JWT 配置
JWT_SECRET=vue3-cesium-threejs-jwt-secret-key-2026
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=vue3-cesium-threejs-refresh-secret-key-2026
JWT_REFRESH_EXPIRES_IN=30d

# 数据库配置
DB_PATH=./data/database.sqlite

# 密码加密强度
BCRYPT_ROUNDS=10

# 限流配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
LOGIN_RATE_LIMIT_MAX=20

# CORS 允许来源（逗号分隔）
CORS_ORIGINS=http://localhost:9527,http://localhost:5173
